def cal_coverage(paf, fai, prefix):
	dictionary = {}
	with gzip.open(paf,"rt") as lines:
		for line in lines:
			temp = line.replace("\n","").split("\t")
			qname = temp[0]
			qlen = int(temp[1])
			qstart = int(temp[2])
			qend = int(temp[3])
			strand = temp[4]

			sname = temp[5]
			slen = int(temp[6])
			sstart = int(temp[7])
			send = int(temp[8])

			matchbp = int(temp[9])
			matchTotalbp = int(temp[10])
			matchquality = int(temp[11])

			key = "_".join(sorted([qname,sname]))
#			key = qname + "_" + sname
		
			qcov =round(matchbp/qlen*100,2)
			scov =round(matchbp/slen*100,2)


			if qcov < scov:
				pseudo_duplicate = sname
			elif qcov > scov:
				pseudo_duplicate = qname
			else:
				pseudo_duplicate = "equal"

			new_line = f"{qname}\t{qstart}\t{qend}\t{sname}\t{sstart}\t{send}\t{qcov}\t{scov}\t{pseudo_duplicate}\n"


			if qname == sname:
				continue

def build_parser():
	usage_text = (
	"Usage: rmdup_prepare -fai {index file} -b {full_table.tsv} -m {selfalign.paf.gz} -p {output prefix}\n\n"
	"Option:\n"
	" -fai, --fai FILE       genome index file.\n"
	" -b, --busco FILE       full_table.tsv from busco result.\n"
	" -m, --mapping FILE     gzip paf file from minimap2 result.\n"
	" -p, --prefix STR       output prefix [default: rm_dup].\n"
	" -v, --version          show version.\n"
	" -h, --help             This message.\n"
	)

	parser = argparse.ArgumentParser(
		prog="rmdup_prepare",
		add_help=False,
		formatter_class=argparse.RawTextHelpFormatter,
		usage=usage_text
	)

	parser.add_argument("-fai", "--fai", required=False)
	parser.add_argument("-b", "--busco", required=False)
	parser.add_argument("-m", "--mapping", required=False)
	parser.add_argument("-p", "--prefix", default="rm_dup")
	parser.add_argument("-v", "--version", action="store_true")
	parser.add_argument("-h", "--help", action="store_true")

	return parser


def main():
	parser = build_parser()
	args = parser.parse_args()

	if args.help or len(sys.argv) == 1:
		print(parser.usage)
		sys.exit(0)
	if args.version:
		print(f"rmdup_prepare v{__version__}")
		sys.exit(0)

	if not args.fai or not args.busco or not args.mapping:
		print("[ERROR] missing required arguments.\n")
		print(parser.usage)
		sys.exit(1)

	prefix = args.prefix

	fai_base = os.path.basename(args.fai)
	fai_order = samtoolsfai_sorting(args.fai)
	print(f"[rmdup_prepare] sorted fai created: sorted_{fai_base}")

	busco_out = make_busco_table(args.busco, fai_order, prefix)
	print(f"[rmdup_prepare] busco table created: {busco_out}")

	paf_out = cal_coverage(args.mapping, fai_order, prefix)
	print(f"[rmdup_prepare] paf table created: {paf_out}")

	print("\nDone.")
	print("Outputs:")
	print(f"  - sorted_{fai_base}")
	print(f"  - {busco_out}")
	print(f"  - {paf_out}")


if __name__ == "__main__":
	main()
	




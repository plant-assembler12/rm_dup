def samtoolsfai_sorting(fai):
	contig_length_list = []
	fai_base = os.path.basename(fai)	

	result = f"sorted_{fai_base}"
	cmd = f"sort -k2,2nr {fai} > {result}"
	os.system(cmd)
	
	with open(result,"r") as lines:
		for line in lines:
			temp = line.split("\t")
			contig = temp[0]
			contig_length_list.append(contig)

	return contig_length_list




		for line in lines:
			temp = line.replace("\n","").split("\t")
			Cname = temp[0]
			length = temp[1]

			fai_dict[Cname] = int(length)



#h1tg000021l: ['98952at3193']
	unique_busco_dict = {}

#h1tg000021l: ['98952at3193', '8828at3193', '20942at3193']
	Total_busco_dict = {}

#ex Total_busco_pos
# h1tg000007l_54811at3193 : ('76355','90281')
	Total_busco_pos = {}


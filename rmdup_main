				if minor_set.issubset(major_set):
					mnst = 0
					mned = fai_dict[mnname]
					minimap_cut = f"{mnname}\ttemp\t{mnst}\t{mned}\ttype1\ttype1_issubset\n"
					SAVE.write(minimap_cut)	
						
				
				else:
	

					minimap_cut = f"{mnname}\ttemp\t{mnst}\t{mned}\ttype1\ttype1_minimap2\n"

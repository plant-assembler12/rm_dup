			Bgene = temp[1]
			Bgene_start = temp[2]
			Bgene_end = temp[3]
			Bgene_state = temp[4].replace("\n","")
			
			pos_key = f"{Cname}_{Bgene}"
			Total_busco_pos[pos_key] = (Bgene_start,Bgene_end)
			
			if Cname not in busco_by_contig:
				busco_by_contig[Cname] = []
			busco_by_contig[Cname].append((Bgene, Bgene_start, Bgene_end, Bgene_state))

			if Cname not in Total_busco_dict:
				Total_busco_dict[Cname] = []
			Total_busco_dict[Cname].append(Bgene)
			

			if "Complete" == Bgene_state:
				if Cname not in unique_busco_dict:
					unique_busco_dict[Cname] = []
				unique_busco_dict[Cname].append(Bgene)



########Type0 Equal
	temp_bed_out = f"{prefix}.temp.bed"			
	
	
	with open(temp_bed_out, "w") as SAVE:

		for equal1, equal2 in equal_list:
			e1 = equal1.split("_")
			e2 = equal2.split("_")

			c1 = e1[0]
			c1st = int(e1[1])
			c1ed = int(e1[2])
			c1_cov = float(e1[3])

			c2 = e2[0]
			c2st = int(e2[1])
			c2ed = int(e2[2])
			c2_cov = float(e2[3])


			if c1 not in Total_busco_dict and c2 in Total_busco_dict:
				if c1_cov > repeat_cov:
					#busco
					minor_name = c1
					mnst = 0
					mned = fai_dict[minor_name]
				
					minimap_cut = f"{minor_name}\ttemp\t{mnst}\t{mned}\ttype0\ttype0_repeat\n"
					SAVE.write(minimap_cut)
				else:
					continue

				
			elif c2 not in Total_busco_dict and c1 in Total_busco_dict:
				if c2_cov > repeat_cov:

					#busco
					minor_name = c2
					mnst = 0
					mned = fai_dict[minor_name]

					minimap_cut = f"{minor_name}\ttemp\t{mnst}\t{mned}\ttype0\ttype0_repeat\n"
					SAVE.write(minimap_cut)
				else:
					continue
				
			elif c1 in Total_busco_dict and c2 in Total_busco_dict:
				c1_set = set(Total_busco_dict[c1])
				c2_set = set(Total_busco_dict[c2])	
				
				if c1_set.issubset(c2_set):
					minor_name = c1
					mnst = 0
					mned = fai_dict[minor_name]
					minimap_cut = f"{minor_name}\ttemp\t{mnst}\t{mned}\ttype0\ttype0_issubset\n"
					SAVE.write(minimap_cut)
				elif c2_set.issubset(c1_set):
					minor_name = c2
					mnst = 0
					mned = fai_dict[minor_name]
					minimap_cut = f"{minor_name}\ttemp\t{mnst}\t{mned}\ttype0\ttype0_issubset\n"
					SAVE.write(minimap_cut)
				else:
							

					#length
					if fai_dict[c1] > fai_dict[c2]:
						minor_name = c2
						mnst = c2st
						mned = c2ed

						minimap_cut = f"{minor_name}\ttemp\t{mnst}\t{mned}\ttype0\ttype0_minimap2\n"
						SAVE.write(minimap_cut)

					elif fai_dict[c1] < fai_dict[c2]:

def minimap2_result(simple_cov_paf,equal_cov, type1_cov, type2_cov):
	TYPE1 = set()
	TYPE2 = set()
	EQUAL = set()
	with open(simple_cov_paf,"r") as lines:
		for line in lines:
			#0qname 1qstart 2qend 3sname 4sstart 5send 6qcov 7scov 8pseudo_duplicate
			temp = line.split("\t")	
			qname = temp[0]
			sname = temp[3]

			qstart = int(temp[1])
			qend = int(temp[2])

			sstart = int(temp[4])
			send = int(temp[5])


			qcov = float(temp[6])
			scov = float(temp[7])
			maxcov = max(qcov, scov)
				
			pseudo_duplicate = temp[8].replace("\n","")

		

			if pseudo_duplicate == "equal" and maxcov >= equal_cov:
				equal1 = f"{qname}_{qstart}_{qend}_{qcov}"
				equal2 = f"{sname}_{sstart}_{send}_{scov}"
				if (equal1,equal2) not in EQUAL:
					EQUAL.add((equal1,equal2))
				continue

			# cov>=70%.. type1 & equal
			if maxcov >= type1_cov:
				#user will remove the minor which is duplicated contig
				if qname == pseudo_duplicate:
					minor=f"{qname}_{qstart}_{qend}_{qcov}"
					major=f"{sname}_{sstart}_{send}_{scov}"
					if (major, minor) not in TYPE1:
						TYPE1.add((major,minor))

				elif sname == pseudo_duplicate:
					minor=f"{sname}_{sstart}_{send}_{scov}"
					major=f"{qname}_{qstart}_{qend}_{qcov}"
					if (major, minor) not in TYPE1:
						TYPE1.add((major,minor))
				else:
					pass
					
			# 70 > cov >=30.. type2 & equal
			elif type1_cov > maxcov >= type2_cov:

				if qname == pseudo_duplicate:
					minor=f"{qname}_{qstart}_{qend}_{qcov}"
					major=f"{sname}_{sstart}_{send}_{scov}"
					if (major, minor) not in TYPE2:
						TYPE2.add((major,minor))
				elif sname == pseudo_duplicate:
					minor=f"{sname}_{sstart}_{send}_{scov}"
					major=f"{qname}_{qstart}_{qend}_{qcov}"
					if (major, minor) not in TYPE2:
						TYPE2.add((major,minor))
				else:
					pass
#	print("EQUAL list : ",EQUAL)
	return TYPE1, TYPE2, EQUAL

def busco_result(parsed_busco, haplo_list, overlap_list,equal_list,repeat_cov, fai,prefix):


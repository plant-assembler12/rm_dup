def build_parser():
	usage_text = (
		"Usage: rmdup_main -sm {sorted.paf} -sb {sorted_full_busco.tsv} -sfai {sorted.fai} -p {prefix}\n\n"
		"Option:\n"
		" -sm, --sorted-paf FILE          simplified paf from rmdup_prepare (*.sorted.paf)\n"
		" -sb, --sorted-busco FILE        sorted busco table from rmdup_prepare (*_sorted_full_busco.tsv)\n"
		" -sfai, --sorted-fai FILE        sorted fai (sorted_*.fai)\n"
		" -t1, --type1 INT        type1 coverage cutoff [default: 70]\n"
		" -t2, --type2 INT        type2 coverage cutoff [default: 50]\n"
		" -t0, --type0 INT        type0 coverage cutoff [default: 50]\n"
		" -r, --repeat INT        repeat/noBUSCO overlap cutoff [default: 50]\n"
		" -p, --prefix STR        output prefix [default: rm_dup]\n"
		" -v, --version           show version\n"
		" -h, --help              This message\n"
	)
	
	parser = argparse.ArgumentParser(
		prog="rmdup_main",
		add_help=False,
		formatter_class=argparse.RawTextHelpFormatter,
		usage=usage_text
	)

	parser.add_argument("-sm", "--sorted-paf", required=False)
	parser.add_argument("-sb", "--sorted-busco", required=False)
	parser.add_argument("-sfai", "--sorted-fai", required=False)
	parser.add_argument("-t1", "--type1", type=int, default=70)
	parser.add_argument("-t2", "--type2", type=int, default=50)
	parser.add_argument("-t0", "--type0", type=int, default=50)
	parser.add_argument("-r", "--repeat", type=int, default=50)
	parser.add_argument("-p", "--prefix", default="rm_dup")
	parser.add_argument("-v", "--version", action="store_true")
	parser.add_argument("-h", "--help", action="store_true")

	return parser


def main():
	parser = build_parser()
	args = parser.parse_args()

	if args.help or len(sys.argv) == 1:
		print(parser.usage)
		sys.exit(0)

	if args.version:
		print(f"rmdup_main v{__version__}")
		sys.exit(0)

	if not args.sorted_paf or not args.sorted_busco or not args.sorted_fai:
		print("[ERROR] missing required arguments.\n")
		print(parser.usage)
		sys.exit(1)

	print("[rmdup_main] Step1: parse paf -> TYPE1/TYPE2/EQUAL")
	haplo_result, overlap_result, equal_result = minimap2_result(args.sorted_paf, args.type0,  args.type1, args.type2)

	print("[rmdup_main] Step2: BUSCO-based decision + temp.bed_out")
	temp_bed_out, busco_dict= busco_result(
		args.sorted_busco, haplo_result, overlap_result, equal_result, args.repeat, args.sorted_fai, args.prefix
	)

	print("[rmdup_main] Step3: noBUSCO contig trimming bed")

	print("\nDone.")
	print("Outputs:")
	print(f"  - {temp_bed_out}")


if __name__ == "__main__":
	main()




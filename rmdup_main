					minimap_cut = f"{minor_name}\ttemp\t{mnst}\t{mned}\ttype0\ttype0_repeat\n"
					SAVE.write(minimap_cut)
					
					continue
			


########TYPE1 haplotig
#ex.TYPE1 list = (major,minor)

#	with open("temp.bed","w") as SAVE:
	with open(temp_bed_out,"a") as SAVE:
